{
  "name": "vscode-hatenablog",
  "displayName": "vscode-hatenablog",
  "description": "test",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hatenablog.post",
        "title": "Post to HatenaBlog"
      }
    ],
    "configuration": {
      "title": "HatenaBlog",
      "properties": {
        "hatenablog.hatenaId": {
          "type": "string",
          "default": "",
          "description": "Hatena ID"
        },
        "hatenablog.blogId": {
          "type": "string",
          "default": "",
          "description": "Blog ID (ブログドメイン e.g. example.hatenablog.com)"
        },
        "hatenablog.apiKey": {
          "type": "string",
          "default": "",
          "description": "API Key"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.100.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "biome": "^0.3.3"
  }
}
