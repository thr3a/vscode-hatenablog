{
  "name": "vscode-hatenablog",
  "displayName": "vscode-hatenablog",
  "description": "test",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hatenablog.post",
        "title": "Post to HatenaBlog"
      }
    ],
    "configuration": {
      "title": "HatenaBlog",
      "properties": {
        "hatenablog.hatenaId": {
          "type": "string",
          "default": "",
          "description": "Hatena ID"
        },
        "hatenablog.blogId": {
          "type": "string",
          "default": "",
          "description": "Blog ID (ブログドメイン e.g. example.hatenablog.com)"
        },
        "hatenablog.apiKey": {
          "type": "string",
          "default": "",
          "description": "API Key"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p ./",
    "dev": "tsc -watch -p ./",
    "pretest": "npm run build && npm run lint",
    "pretest:unit": "npm run build && npm run lint",
    "lint": "biome check --write --unsafe ./src && npx tsc --noEmit",
    "test:unit": "mocha --ui tdd \"out/test/unit/**/*.test.js\"",
    "test:integration": "vscode-test",
    "test": "npm run test:unit && npm run test:integration"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.100.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "typescript": "^5.9.3"
  },
  "imports": {
    "#*": {
      "types": "./src/*.ts",
      "default": "./out/*.js"
    }
  }
}
